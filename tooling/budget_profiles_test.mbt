///|
test "named budget profiles expose render and wechat budgets" {
  assert_eq(is_named_budget_profile("default"), true)
  assert_eq(is_named_budget_profile("tight"), true)
  assert_eq(is_named_budget_profile("tiny"), true)
  assert_eq(is_named_budget_profile("unknown"), false)
  let tight_render = render_budget_for_profile("tight")
  assert_eq(tight_render.max_nodes, 128)
  assert_eq(tight_render.max_initial_data_bytes, 4096)
  assert_eq(tight_render.max_unwindowed_list_children, 16)
  assert_eq(tight_render.max_scene_markers, 64)
  assert_eq(tight_render.max_scene_assets, 16)
  let tiny_render = render_budget_for_profile("tiny")
  assert_eq(tiny_render.max_nodes, 8)
  assert_eq(tiny_render.max_events, 1)
  assert_eq(tiny_render.max_initial_data_bytes, 64)
  assert_eq(tiny_render.max_scene_assets, 0)
  let tight_wechat = wechat_build_budget_for_profile("tight")
  assert_eq(tight_wechat.max_files, 16)
  assert_eq(tight_wechat.max_total_bytes, 32768)
  assert_eq(tight_wechat.max_page_update_payload_bytes, 1024)
  let tiny_wechat = wechat_build_budget_for_profile("tiny")
  assert_eq(tiny_wechat.max_files, 1)
  assert_eq(tiny_wechat.max_total_bytes, 128)
  assert_eq(tiny_wechat.max_page_first_screen_bytes, 4)
  let tight_inspection = inspection_budget_for_profile("tight")
  assert_eq(tight_inspection.max_route_risk_score, 50000)
  assert_eq(tight_inspection.max_update_payload_bytes, 1024)
  assert_eq(tight_inspection.max_update_operations, 16)
  assert_eq(tight_inspection.max_backend_events, 16)
  assert_eq(tight_inspection.max_backend_streams, 4)
  assert_eq(tight_inspection.max_backend_reviews, 8)
  assert_eq(tight_inspection.max_backend_cancels, 8)
  assert_eq(tight_inspection.max_backend_retries, 8)
  assert_eq(tight_inspection.max_scene_assets, 16)
  assert_eq(tight_inspection.max_scene_remote_assets, 4)
  assert_eq(tight_inspection.max_scene_package_bytes, 256 * 1024)
  let tiny_inspection = inspection_budget_for_profile("tiny")
  assert_eq(tiny_inspection.max_route_risk_score, 1000)
  assert_eq(tiny_inspection.max_update_payload_bytes, 0)
  assert_eq(tiny_inspection.max_update_operations, 0)
  assert_eq(tiny_inspection.max_backend_events, 0)
  assert_eq(tiny_inspection.max_backend_streams, 0)
  assert_eq(tiny_inspection.max_backend_reviews, 0)
  assert_eq(tiny_inspection.max_backend_cancels, 0)
  assert_eq(tiny_inspection.max_backend_retries, 0)
  assert_eq(tiny_inspection.max_scene_assets, 0)
  assert_eq(tiny_inspection.max_scene_remote_assets, 0)
  assert_eq(tiny_inspection.max_scene_package_bytes, 0)
  let tight_profile = build_profile_budget_for_profile("tight")
  assert_eq(tight_profile.max_agent_duplicate_stream_chunks, 0)
  assert_eq(tight_profile.max_communication_unresolved_reviews, 8)
  assert_eq(tight_profile.max_tool_result_missing_acks, 0)
  assert_eq(tight_profile.max_snapshot_full_replaces, 0)
  assert_eq(tight_profile.max_scene_thread_orphans, 0)
  assert_eq(tight_profile.max_scene_camera_clamped, 0)
  assert_eq(tight_profile.max_scene_surface_fallbacks, 0)
  assert_eq(tight_profile.max_scene_quality_issues, 0)
  assert_eq(tight_profile.max_degraded_scenes, 0)
  let default_profile = build_profile_budget_for_profile("default")
  assert_eq(default_profile.max_communication_unresolved_reviews, 16)
  assert_eq(default_profile.max_tool_result_missing_acks, 0)
  assert_eq(default_profile.max_snapshot_full_replaces, 1)
  assert_eq(default_profile.max_scene_surface_fallbacks, 4)
}
