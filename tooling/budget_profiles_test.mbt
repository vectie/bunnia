///|
test "named budget profiles expose render and wechat budgets" {
  assert_eq(is_named_budget_profile("default"), true)
  assert_eq(is_named_budget_profile("tight"), true)
  assert_eq(is_named_budget_profile("tiny"), true)
  assert_eq(is_named_budget_profile("unknown"), false)
  let tight_render = render_budget_for_profile("tight")
  assert_eq(tight_render.max_nodes, 128)
  assert_eq(tight_render.max_initial_data_bytes, 4096)
  assert_eq(tight_render.max_unwindowed_list_children, 16)
  assert_eq(tight_render.max_scene_markers, 64)
  let tiny_render = render_budget_for_profile("tiny")
  assert_eq(tiny_render.max_nodes, 8)
  assert_eq(tiny_render.max_events, 1)
  assert_eq(tiny_render.max_initial_data_bytes, 64)
  let tight_wechat = wechat_build_budget_for_profile("tight")
  assert_eq(tight_wechat.max_files, 16)
  assert_eq(tight_wechat.max_total_bytes, 32768)
  assert_eq(tight_wechat.max_page_update_payload_bytes, 1024)
  let tiny_wechat = wechat_build_budget_for_profile("tiny")
  assert_eq(tiny_wechat.max_files, 1)
  assert_eq(tiny_wechat.max_total_bytes, 128)
  assert_eq(tiny_wechat.max_page_first_screen_bytes, 4)
}
