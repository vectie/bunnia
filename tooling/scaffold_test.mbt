  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "moon run cmd/main -- build --out _build/wechat\\{strict_flag}",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "diagnostic=\\{item}",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "route_diagnostic=\\{page.route}:\\{item}",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "inspection_diagnostic=\\{item}",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "profile_gate_diagnostic=\\{item}",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("starter_snapshot"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "print_inspect_result",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("inspection_gate"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "inspection_gate_diagnostics",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "profile_gate_diagnostics",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "build_failed=diagnostics",
    ),
  )
  assert_true(file_content(plan.files, "app.mbt").contains("pub fn view()"))
  assert_true(
    file_content(plan.files, "app.mbt").contains("starter_agent_feed"),
  )
  assert_true(
    file_content(plan.files, "agent_feed.mbt").contains("windowed_message_feed"),
  )
  assert_true(
    file_content(plan.files, "app.mbt").contains("surface_status_overlay"),
  )
  assert_true(file_content(plan.files, "scene.mbt").contains("starter_scene"))
  assert_true(file_content(plan.files, "scene.mbt").contains("bunnia.region"))
  assert_true(file_content(plan.files, "app.mbt").contains("static_scene_view"))
  assert_true(
    file_content(plan.files, "scene.mbt").contains("pub fn scene_render_plan()"),
  )
  assert_true(
    file_content(plan.files, "updates.mbt").contains("select_scene_marker"),
  )
  assert_true(
    file_content(plan.files, "updates.mbt").contains("select_scene_region"),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("scene_region_count"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn render_plan()"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("strict_render_plan"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn backend_plan()"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn effect_plan()"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn build_profile"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains(
      "pub fn project_inspection",
    ),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn inspection_gate"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains("pub fn profile_gate"),
  )
  assert_true(
    file_content(plan.files, "quality.mbt").contains(
      "render_budget_for_profile",
    ),
  )
  assert_true(
    file_content(plan.files, "wechat.mbt").contains("starter_wechat_project"),
  )
  assert_true(
    file_content(plan.files, "wechat.mbt").contains("starter_backend_contract"),
  )
  assert_true(
    file_content(plan.files, "wechat.mbt").contains("agent_message_endpoint"),
  )
  assert_true(
    file_content(plan.files, "wechat.mbt").contains(
      "generate_wechat_project_with_runtime_and_budget_and_backend",
    ),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("strict_render_plan"),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("starter updates"),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("clean wechat output"),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("backend_event_count"),
  )
  assert_true(
    file_content(plan.files, "app_test.mbt").contains("inspection_gate"),
  )
  assert_true(file_content(plan.files, "app_test.mbt").contains("profile_gate"))
  assert_true(
    file_content(plan.files, "updates.mbt").contains(
      "append_stream_chunk_delta",
    ),
  )
  assert_true(
    file_content(plan.files, "README.mbt.md").contains("starter tests"),
  )
  assert_true(
    file_content(plan.files, "README.mbt.md").contains("inspection gates"),
  )
  assert_true(file_content(plan.files, "README.mbt.md").contains("inspect"))
  assert_true(file_content(plan.files, "README.mbt.md").contains("snapshot"))
  assert_true(file_content(plan.files, "README.mbt.md").contains("ci-plan"))
  assert_true(
    file_content(plan.files, "README.mbt.md").contains("ci-plan --script"),
  )
  assert_true(
    file_content(plan.files, "README.mbt.md").contains("limits --target wechat"),
  )
  assert_true(file_content(plan.files, "README.mbt.md").contains("moon info"))
  assert_true(file_content(plan.files, "README.mbt.md").contains("moon fmt"))
  assert_true(file_content(plan.files, "README.mbt.md").contains("--strict"))
  assert_true(
    file_content(plan.files, "README.mbt.md").contains(
      "build --out _build/wechat",
    ),
  )
  assert_true(plan.summary.contains("files=12"))
}

///|
test "scaffold project defaults module name from app name" {
  let plan = scaffold_project(name="demo_app")
  assert_eq(plan.module_name, "local/demo_app")
}

///|
fn has_file(files : Array[ScaffoldFile], path : String) -> Bool {
  for item in files {
    if item.path == path {
      return true
    }
  }
  false
}

///|
fn file_content(files : Array[ScaffoldFile], path : String) -> String {
  for item in files {
    if item.path == path {
      return item.content
    }
  }
  ""
}
