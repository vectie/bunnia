///|
test "scaffold project creates a small standalone starter" {
  let plan = scaffold_project(name="starter", module_name="local/starter")
  assert_eq(plan.name, "starter")
  assert_eq(plan.module_name, "local/starter")
  assert_eq(plan.files.length(), 12)
  assert_true(has_file(plan.files, "moon.mod"))
  assert_true(has_file(plan.files, "moon.pkg"))
  assert_true(has_file(plan.files, "cmd/main/moon.pkg"))
  assert_true(has_file(plan.files, "cmd/main/main.mbt"))
  assert_true(has_file(plan.files, "app.mbt"))
  assert_true(has_file(plan.files, "agent_feed.mbt"))
  assert_true(has_file(plan.files, "scene.mbt"))
  assert_true(has_file(plan.files, "updates.mbt"))
  assert_true(has_file(plan.files, "quality.mbt"))
  assert_true(has_file(plan.files, "wechat.mbt"))
  assert_true(has_file(plan.files, "app_test.mbt"))
  assert_true(has_file(plan.files, "README.mbt.md"))
  assert_true(
    file_content(plan.files, "moon.mod").contains("name = \"local/starter\""),
  )
  assert_true(
    file_content(plan.files, "moon.mod").contains("\"vectie/bunnia@0.1.0\""),
  )
  assert_true(
    file_content(plan.files, "moon.pkg").contains("\"vectie/bunnia\""),
  )
  assert_true(
    file_content(plan.files, "cmd/main/moon.pkg").contains(
      "\"local/starter\" @app",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/moon.pkg").contains("\"vectie/bunnia\""),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "starter_wechat_project",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("write_text_file"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("strict_from_args"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "ci_script_from_args",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("command_from_args"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "snapshot_output_path_from_args",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("print_ci_plan"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("print_ci_script"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "print_platform_limits",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "platform_limits(target=target_from_args(@env.args()))",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("target_from_args"),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains("generator_status="),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "inspection_gate.summary",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "profile_gate.summary",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "build --out _build/wechat",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "step=limits command=moon run cmd/main -- limits --target wechat",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "step=info command=moon info",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "step=fmt command=moon fmt",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "let diagnostics = project.report.diagnostics.length()",
    ),
  )
  assert_true(
    file_content(plan.files, "cmd/main/main.mbt").contains(
      "Bunnia starter CI plan: steps=8 diagnostics=\\{diagnostics}",
