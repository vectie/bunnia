///|
fn tile_messages_wxss() -> String {
  ".moontown-chat-list-header { display: flex; align-items: center; justify-content: space-between; gap: 10rpx; }\n" +
  ".moontown-chat-refresh { flex: 0 0 88rpx; width: 88rpx; min-width: 88rpx; padding: 0; font-size: 30rpx; }\n" +
  ".moontown-notice-list > .bunnia-list-windowed { gap: 0; margin-top: 8rpx; }\n" +
  ".moontown-chat-row { min-width: 0; min-height: 88rpx; margin: 0; display: grid; grid-template-columns: 64rpx minmax(0, 1fr); gap: 12rpx; padding: 12rpx 4rpx; border-bottom: 1rpx solid rgba(51,65,55,0.16); background: transparent; overflow: visible; }\n" +
  ".moontown-chat-row:active { background: rgba(37,99,235,0.08); }\n" +
  ".moontown-chat-row.unread { background: rgba(255,241,242,0.48); }\n" +
  ".moontown-chat-avatar { display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; border-radius: 8rpx; background: #203124; color: #ffffff; font-size: 22rpx; font-weight: 800; }\n" +
  ".moontown-chat-avatar.kind-agent-run { background: #2563eb; }\n" +
  ".moontown-chat-avatar.kind-review { background: #d69e2e; color: #1f2937; }\n" +
  ".moontown-chat-avatar.kind-interaction { background: #2f855a; }\n" +
  ".moontown-chat-avatar.kind-follow { background: #e11d48; }\n" +
  ".moontown-chat-copy { min-width: 0; }\n" +
  ".moontown-chat-title-row { display: flex; align-items: center; justify-content: space-between; gap: 8rpx; min-width: 0; }\n" +
  ".moontown-chat-title-row .mt-title { min-width: 0; flex: 1 1 auto; }\n" +
  ".moontown-chat-unread-dot { flex: 0 0 12rpx; width: 12rpx; height: 12rpx; border-radius: 6rpx; background: #e11d48; }\n" +
  ".moontown-chat-preview, .moontown-chat-preview text { min-width: 0; margin-top: 2rpx; color: #53624e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n"
}
