///|
fn tile_content_wxss() -> String {
  ".moontown-section-label { margin-top: 12rpx; color: #334538; font-size: 18rpx; font-weight: 800; }\n" +
  ".moontown-primary-action { border-color: #203124; background: #203124; color: #ffffff; font-weight: 800; }\n" +
  ".moontown-secondary-action { background: transparent; color: #334538; }\n" +
  ".moontown-danger-action { color: #9f1239; font-weight: 700; }\n" +
  ".moontown-home-lead { margin-top: 0; padding: 16rpx; border: 2rpx solid rgba(32,49,36,0.28); border-radius: 8rpx; }\n" +
  ".moontown-home-lead .mt-title, .moontown-home-lead .mt-title text { font-size: 28rpx !important; line-height: 36rpx; white-space: normal; overflow: visible; text-overflow: clip; }\n" +
  ".moontown-home-lead button { width: 100%; margin-top: 12rpx; }\n" +
  ".moontown-home-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10rpx; margin-top: 12rpx; }\n" +
  ".moontown-home-stat { min-width: 0; padding-top: 8rpx; border-top: 3rpx solid #2563eb; color: #53624e; font-size: 16rpx; }\n" +
  ".moontown-home-stat-value { color: #203222; font-size: 28rpx; font-weight: 800; }\n" +
  ".moontown-district-grid .bunnia-list-windowed { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8rpx; margin-top: 8rpx; }\n" +
  ".moontown-district-actions { display: flex; gap: 8rpx; margin-top: 8rpx; }\n" +
  ".moontown-district-entry.tone-blue { border-color: rgba(49,130,206,0.44); background: rgba(231,243,255,0.72); }\n" +
  ".moontown-district-entry.tone-orange { border-color: rgba(221,107,32,0.42); background: rgba(255,238,214,0.72); }\n" +
  ".moontown-district-entry.tone-purple { border-color: rgba(128,90,213,0.38); background: rgba(241,234,255,0.72); }\n" +
  ".moontown-district-entry.tone-pink { border-color: rgba(213,63,140,0.34); background: rgba(255,232,242,0.72); }\n" +
  ".moontown-district-entry.tone-green { border-color: rgba(56,161,105,0.42); background: rgba(226,246,231,0.72); }\n" +
  ".moontown-presence-row .bunnia-list-windowed { display: flex; flex-direction: row; gap: 8rpx; overflow-x: auto; overflow-y: hidden; }\n" +
  ".moontown-presence-chip { flex: 0 0 136rpx; min-width: 0; }\n" +
  ".moontown-attention-rows .bunnia-list-windowed { display: flex; flex-direction: column; gap: 8rpx; margin-top: 8rpx; overflow: hidden; }\n" +
  ".moontown-onboarding-compact .moontown-primary-action { width: 100%; margin-top: 10rpx; }\n" +
  ".moontown-discovery-search { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 8rpx; align-items: stretch; margin-top: 10rpx; }\n" +
  ".mt-panel .moontown-discovery-search input { margin-top: 0; }\n" +
  ".moontown-results-heading { margin-top: 14rpx; padding-top: 12rpx; border-top: 1rpx solid rgba(51,65,55,0.18); }\n" +
  ".moontown-discovery-results .bunnia-list-windowed { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10rpx; }\n" +
  ".moontown-discover-entry { display: flex; flex-direction: column; min-height: 196rpx; }\n" +
  ".moontown-discover-entry > .moontown-discovery-action { margin-top: auto; padding-top: 8rpx; }\n" +
  ".moontown-discovery-action .moontown-primary-action { flex: 2 1 160rpx; }\n" +
  ".moontown-message-inbox, .moontown-message-notices { grid-column: 1 / -1; }\n" +
  ".moontown-discovery-filters .bunnia-list-windowed, .moontown-message-channels .bunnia-list-windowed, .moontown-ownership-filters .bunnia-list-windowed, .moontown-lifecycle-actions, .moontown-lifecycle-stages { display: flex; flex-direction: row; gap: 8rpx; overflow-x: auto; overflow-y: hidden; margin-top: 8rpx; }\n" +
  ".moontown-lifecycle-stage { flex: 0 0 auto; min-height: 36rpx; padding: 6rpx 8rpx; font-size: 16rpx; line-height: 24rpx; }\n" +
  ".moontown-discovery-filter, .moontown-message-channel, .moontown-ownership-filter { flex: 0 0 auto; min-height: 88rpx; padding: 10rpx 12rpx; border: 1rpx solid rgba(51,65,55,0.18); border-radius: 6rpx; background: rgba(239,246,255,0.74); color: #334538; font-size: 18rpx; line-height: 28rpx; overflow: hidden; }\n" +
  ".moontown-discovery-filter.active, .moontown-message-channel.active, .moontown-ownership-filter.active { background: #2563eb; color: #ffffff; }\n"
}
