///|
fn tile_responsive_wxss() -> String {
  "@media (max-width: 520px) { .moontown-topbar { left: 16rpx; right: 16rpx; } .moontown-subtitle { max-width: 420rpx; } .moontown-passport-entry, .moontown-entry-button { min-width: 136rpx; max-width: 184rpx; } .moontown-page-surface { left: 16rpx; right: 16rpx; } .moontown-page-grid, .moontown-page-grid.three, .moontown-my-layout { grid-template-columns: 1fr; } .moontown-my-layout > * { grid-column: auto; grid-row: auto; } .moontown-my-overview { order: 1; } .moontown-my-setup { order: 2; } .moontown-my-inventory { order: 3; } .moontown-my-public { order: 4; } .moontown-my-lifecycle { order: 5; } .moontown-my-reviewer { order: 8; } .moontown-create-drawer { display: none; } .moontown-right-hud { left: 16rpx; right: 16rpx; top: 160rpx; width: auto; } .moontown-bottom-hud { left: 16rpx; right: 16rpx; } }"
}
