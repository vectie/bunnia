///|
fn tile_base_wxss() -> String {
  ".moontown-miniapp { position: relative; min-height: 100vh; overflow: hidden; background: #0f172a; color: #17221b; font-size: 26rpx; line-height: 1.45; overflow-wrap: anywhere; word-break: break-word; overscroll-behavior: contain; }\n" +
  "view, button, input { box-sizing: border-box; }\n" +
  "button { min-width: 88rpx; min-height: 88rpx; max-width: 100%; margin: 0; padding: 10rpx 18rpx; border: 1rpx solid #cbd5e1; border-radius: 6rpx; background: #ffffff; color: #24332a; font-size: 24rpx; line-height: 32rpx; overflow: hidden; touch-action: manipulation; }\n" +
  "button::after { border: 0; }\n" +
  "button:active { opacity: 0.82; }\n" +
  "button[disabled], .bunnia-status-disabled { opacity: 0.52; pointer-events: none; }\n" +
  "button text { white-space: normal; text-align: center; overflow-wrap: anywhere; word-break: break-word; }\n" +
  ".mt-panel input { width: 100%; min-height: 88rpx; margin-top: 8rpx; padding: 0 18rpx; border: 1rpx solid #cbd5e1; border-radius: 6rpx; background: #ffffff; color: #17221b; font-size: 26rpx; }\n"
}
