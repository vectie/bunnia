///|
fn reviewer_wxss_source() -> String {
  ".moontown-miniapp { min-height: 100vh; background: #0f172a; color: #16221a; font-size: 24rpx; line-height: 1.35; overflow-wrap: anywhere; word-break: break-word; }\n" +
  ".moontown-page-surface { position: relative; left: auto; right: auto; top: auto; bottom: auto; min-height: 100vh; margin: 0; padding: 24rpx; box-sizing: border-box; overflow: visible; background: #eef2f7; }\n" +
  ".moontown-credential-plaque { padding: 18rpx; border: 2rpx solid #2563eb; border-radius: 8rpx; background: #f8fafc; box-shadow: 0 6rpx 18rpx rgba(15,23,42,0.14); }\n" +
  ".mt-title { margin-bottom: 8rpx; color: #203124; font-size: 30rpx; line-height: 38rpx; font-weight: 800; }\n" +
  ".mt-meta { margin-top: 8rpx; color: #53624e; font-size: 20rpx; line-height: 28rpx; }\n" +
  ".moontown-diagnostic-section { margin-top: 16rpx; padding: 14rpx; border: 1rpx solid rgba(51,65,55,0.18); border-top: 3rpx solid #e11d48; border-radius: 6rpx; background: rgba(248,250,252,0.96); }\n" +
  ".moontown-diagnostic-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8rpx; margin-top: 10rpx; }\n" +
  ".moontown-diagnostic-row { min-width: 0; padding: 10rpx; border-left: 4rpx solid #2563eb; border-radius: 6rpx; background: rgba(239,246,255,0.78); color: #203124; font-size: 18rpx; line-height: 26rpx; box-sizing: border-box; overflow: hidden; }\n" +
  ".moontown-diagnostic-row text { display: block; overflow: hidden; text-overflow: ellipsis; }\n" +
  ".moontown-community-actions { display: flex; gap: 10rpx; margin-top: 14rpx; flex-wrap: wrap; }\n" +
  "button { min-width: 88rpx; min-height: 88rpx; padding: 8rpx 18rpx; border: 1rpx solid #203124; border-radius: 6rpx; background: #203124; color: #ffffff; font-size: 20rpx; line-height: 28rpx; touch-action: manipulation; }"
}
