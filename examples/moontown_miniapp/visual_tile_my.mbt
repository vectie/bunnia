///|
fn tile_my_wxss() -> String {
  ".moontown-my-layout { grid-template-columns: minmax(0, 1fr); align-items: start; }\n" +
  ".moontown-my-overview { min-width: 0; }\n" +
  ".moontown-my-inventory { background: #ffffff; }\n" +
  ".moontown-my-overview > .moontown-profile-card { margin-top: 0; }\n" +
  ".moontown-my-attention { margin-top: 14rpx; padding-top: 14rpx; border-top: 1rpx solid #dbe3df; }\n" +
  ".moontown-my-attention > .bunnia-list-windowed { display: flex; flex-direction: column; gap: 8rpx; margin-top: 8rpx; }\n" +
  ".moontown-my-attention .moontown-workbench-alert { margin-top: 0; }\n" +
  ".moontown-my-inventory > .bunnia-list-windowed { display: grid; grid-template-columns: minmax(0, 1fr); gap: 8rpx; }\n" +
  ".moontown-my-public, .moontown-my-lifecycle, .moontown-my-reviewer, .moontown-create-drawer { margin-top: 6rpx; }\n"
}
