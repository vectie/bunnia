///|
fn tile_state_wxss() -> String {
  ".bunnia-status-review, .bunnia-status-pending, .bunnia-status-stale, .bunnia-status-waiting { border-color: #d69e2e; background: #ffffff; }\n" +
  ".bunnia-status-stable, .bunnia-status-ready, .bunnia-status-published { border-color: #2f855a; background: #ffffff; }\n" +
  ".bunnia-status-current, .bunnia-status-running { border-color: #2563eb; background: #ffffff; }\n" +
  ".bunnia-status-blocked, .bunnia-status-failed { border-color: #c64438; background: #ffffff; }\n" +
  ".bunnia-status-draft, .bunnia-status-shared { border-color: #64748b; background: #ffffff; }\n"
}
